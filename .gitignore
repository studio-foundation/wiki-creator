# Misc
.DS_Store
*.pem

# Books (EPUBs ignored, YAML configs tracked)
/books/
!books/**/*.yaml
library/**/*.epub
!library/**/*.yaml

# Sanctioned bench/test corpus (STU-623): a throwaway book placed here still
# lives under library/<author>/<series>/, so its derived paths match the
# expected_outputs globs (library/*/*/...) and its contracts pass. Whole dir
# ignored — bench yaml/epub/output are never committed.
library/_bench/

# Pipeline output dirs (per-series)
library/**/processing_output/
library/**/wiki_inputs/
library/**/output/
library/**/registry.json
library/**/character_graph.json
# public_domain ships its EPUBs + YAMLs (distributable), and its exported wikis
# (output/) ARE committed as demo artifacts (STU-617) — the point of the corpus is
# to show a built wiki. The intermediate artifacts stay out of git: regenerable,
# large, and not the deliverable.
public_domain/**/processing_output/
public_domain/**/wiki_inputs/
public_domain/**/registry.json
public_domain/**/character_graph.json
.wiki_runs/

# Per-book run snapshots (CLAUDE.local.md "Back Up Before Running On A Real Book":
# bak_<DD-MM-YY>/ next to a book's output dirs). Local audit scratch, never committed.
bak_*/

# Fandom survey corpus — regenerable from scripts/fandom_wikis.yaml, and large
# (raw_wikitext per page + every infobox Template: page, per wiki). The curated
# datasets under processing_output/fandom/ stay tracked; this is the scratch
# survey, not a deliverable.
processing_output/fandom_corpus/

# Scratch audits at repo root; per-book audit logs under library/ stay tracked
/audits/
# Research eval outputs: per-book arm extractions + the oracle verdicts (STU-535)
research/*/arms/
# ner-eval STU-616: per-book oracle rosters + batch log. Regenerable by
# batch_all.sh; the judged numbers live in research/ner-eval/results_stu616.md.
research/ner-eval/stu616/
# alias-eval: per-book adjudication verdicts + run log (STU-543). Regenerable by
# run_books.py; the judged numbers live in research/alias-eval/results.md.
research/alias-eval/verdicts/
research/alias-eval/run.log
# embedding-eval: masked mention windows + their encodings (STU-576). Regenerable by
# build_corpus.py from the processing_output caches, which are themselves gitignored.
research/embedding-eval/corpus/

# Local, per-machine agent notes
CLAUDE.local.md
